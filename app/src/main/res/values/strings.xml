<?xml version="1.0" encoding="utf-8"?>
<resources>
    <string name="app_name">Roz Kamai</string>

    <!-- Onboarding -->
    <string name="onboarding_trust_title">Aapka paisa safe hai</string>
    <string name="onboarding_trust_body">Paisa seedha aapke account mein aata hai.\nHum sirf payment messages padhte hain.\nKoi bank login nahi chahiye.</string>
    <string name="onboarding_feature_title">Roz ka hisaab, bina kuch likhe</string>
    <string name="onboarding_how_title">Kaise kaam karta hai?</string>
    <string name="onboarding_how_body">Payment aayega → SMS aayega → Hum gin lenge.\nBas SMS permission do, baaki hum sambhaal lenge.</string>

    <!-- Permissions -->
    <string name="permission_sms_title">SMS access chahiye</string>
    <string name="permission_sms_body">Hum sirf bank aur UPI messages padhte hain.\nPersonal messages nahi.\nAapka data phone mein hi rehta hai — kuch bhi bahar nahi jaata.</string>
    <string name="permission_sms_grant_button">Ijazat do</string>
    <string name="permission_sms_rationale_title">Ek baar aur try karein</string>
    <string name="permission_sms_rationale_body">SMS permission ke bina hum aapki income track nahi kar sakte.\nKoi personal message nahi padhte — sirf bank aur UPI alerts.</string>
    <string name="permission_sms_try_again_button">Try again</string>
    <string name="permission_sms_denied_title">Settings mein jaana hoga</string>
    <string name="permission_sms_denied_body">Aapne permission permanently deny kar diya.\nSettings mein jaake SMS permission on karein.</string>
    <string name="permission_sms_rationale">Hum sirf bank aur UPI messages padhte hain.\nPersonal messages nahi.\nAapka data phone mein hi rehta hai.</string>
    <string name="permission_sms_denied">SMS permission ke bina app kaam nahi kar payega</string>
    <string name="permission_settings_button">Settings kholein</string>

    <!-- Notification channels (P3-002) -->
    <string name="notif_channel_eod_name">Aaj ki kamai</string>
    <string name="notif_channel_eod_desc">Roz shaam ko aaj ka hisaab milega</string>
    <string name="notif_channel_midday_name">Income alert</string>
    <string name="notif_channel_midday_desc">Jab kamai expected se kam ho</string>
    <string name="notif_channel_inactivity_name">Koi payment nahi</string>
    <string name="notif_channel_inactivity_desc">Jab 2 ghante se koi payment nahi aaye</string>

    <!-- EOD summary notification (P3-003) -->
    <string name="notif_eod_title">Aaj ka hisaab</string>
    <string name="notif_eod_body_plain">Aaj %1$s aaya — %2$d payment</string>
    <string name="notif_eod_body_more">Aaj %1$s aaya — kal se %2$s zyada!</string>
    <string name="notif_eod_body_less">Aaj %1$s aaya — kal se %2$s kam</string>
    <string name="notif_eod_body_same">Aaj %1$s aaya — kal jitna hi</string>

    <!-- Mid-day alert notification (P3-004) -->
    <string name="notif_midday_title">Income check</string>
    <string name="notif_midday_body">Abhi sirf %1$s aaya — expected %2$s se kam hai. Dhyan do!</string>

    <!-- Inactivity alert notification (P3-005) -->
    <string name="notif_inactivity_title">Payment nahi aaya</string>
    <string name="notif_inactivity_body">%1$d ghante se koi payment nahi — sab theek hai?</string>

